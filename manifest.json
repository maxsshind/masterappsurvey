{
  "manifest_version": 3,
  "name": "CoStar → Survey Pusher",
  "version": "1.2.7",
  "description": "Push the CoStar property on your screen into a master-app survey or the comps database. Read-only on CoStar.",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "sidePanel"
  ],

  "host_permissions": [
    "https://*.costar.com/*",
    "https://*.csgpimgs.com/*",
    "https://kavynghiailoduhulytq.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "panel.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
